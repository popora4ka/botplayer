local function StartBot()
    if Bot.Connection then return end
    
    Bot.Connection = RunService.RenderStepped:Connect(function()
        if not Bot.Enabled then return end
        
        local gameInfo = GetGameInfo()
        
        -- Обновление ESP
        UpdateESP()
        
        -- Сбор монет
        if Bot.CollectCoins and gameInfo.Alive then
            CollectNearestCoins()
        end
        
        -- Побег от мардера
        if Bot.AutoEscapeMurderer and gameInfo.Murderer and gameInfo.Alive then
            EscapeFromMurderer()
        end
        
        -- Автоматическая стрельба за шерифа
        if Bot.AutoShootSheriff and gameInfo.Sheriff == LocalPlayer and gameInfo.Murderer then
            local localChar = LocalPlayer.Character
            if localChar then
                -- Поиск оружия
                local hasGun = false
                for _, tool in ipairs(localChar:GetChildren()) do
                    if tool:IsA("Tool") and (tool.Name:lower():find("gun") or tool.Name:lower():find("pistol")) then
                        hasGun = true
                        break
                    end
                end
                
                if hasGun then
                    ShootAtPlayer(gameInfo.Murderer)
                elseif Bot.AutoPickupGun then
                    -- Подбор оружия
                    local gun = FindGun()
                    if gun and time() - Bot.LastPickupTime > 2 then
                        Bot.LastPickupTime = time()
                        local distance = (localChar.HumanoidRootPart.Position - gun.Position).Magnitude
                        if distance < 50 then
                            TweenToPosition(gun.Position, Bot.WalkSpeed)
                        end
                    end
                end
            end
        end
        
        -- Прохождение препятствий
        if Bot.AutoPassObstacles and gameInfo.Alive then
            CheckAndPassObstacles()
        end
        
        -- Голосование за карту
        if Bot.AutoVote and not gameInfo.RoundActive then
            VoteForMap("Bank") -- Можно изменить на любую карту
        end
    end)
end

local function StopBot()
    if Bot.Connection then
        Bot.Connection:Disconnect()
        Bot.Connection = nil
    end
    ClearESP()
end

