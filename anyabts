-- ===== CORE FUNCTIONS =====
local function GetRole(player)
    local character = player.Character
    if not character then return nil end
    local backpack = player:FindFirstChild("Backpack")
    if character:FindFirstChild("Knife") or (backpack and backpack:FindFirstChild("Knife")) then
        return "Murderer"
    elseif character:FindFirstChild("Gun") or (backpack and backpack:FindFirstChild("Gun")) then
        return "Sheriff"
    end
    return "Innocent"
end

local function ShouldESP(player, filter)
    local role = GetRole(player)
    if not role then return false end
    if table.find(filter, "Esp All") then return true end
    if table.find(filter, "Esp Murder") and role == "Murderer" then return true end
    if table.find(filter, "Esp Sheriff") and role == "Sheriff" then return true end
    if table.find(filter, "Esp Sheriff / Murder") and (role == "Sheriff" or role == "Murderer") then return true end
    return false
end

local function ApplyHighlight(character, color)
    local highlight = character:FindFirstChild("RoleHighlight")
    if not highlight then
        highlight = Instance.new("Highlight")
        highlight.Name = "RoleHighlight"
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 1
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Adornee = character
        highlight.Parent = character
    end
    highlight.FillColor = color
end

local function RemoveHighlight(character)
    local highlight = character:FindFirstChild("RoleHighlight")
    if highlight then highlight:Destroy() end
end

local function DrawTracer(player, color)
    if tracers[player] then
        tracers[player].Color = color
        return
    end
    local line = Drawing.new("Line")
    line.Thickness = 2
    line.Color = color or Color3.new(1, 1, 1)
    line.Transparency = 1
    tracers[player] = line
end

local function RemoveTracer(player)
    if tracers[player] then
        tracers[player]:Remove()
        tracers[player] = nil
    end
end

local function UpdateESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer and player.Character then
            local role = GetRole(player)
            if role == "Murderer" then isMurderer = true end
            if role == "Sheriff" then isSheriff = true end
        end
        
        if player ~= LocalPlayer and player.Character then
            local role = GetRole(player)
            local shouldShow = ShouldESP(player, espFilter)
            
            if highlightESP and shouldShow then
                local color = role == "Murderer" and Colors.Blood or (role == "Sheriff" and Colors.Toxic or Colors.Woloko)
                ApplyHighlight(player.Character, color)
            else
                RemoveHighlight(player.Character)
            end
            
            if lineESP and shouldShow then
                local color = role == "Murderer" and Colors.Blood or (role == "Sheriff" and Colors.Toxic or Colors.Woloko)
                DrawTracer(player, color)
            else
                RemoveTracer(player)
            end
        end
    end
end

