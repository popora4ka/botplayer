-- ===== СИСТЕМА ПАМЯТИ =====
local MemorySystem = {
    -- Добавление события в память
    Remember = function(eventType, data, importance)
        importance = importance or 0.5
        
        local memory = {
            Type = eventType,
            Data = data,
            Timestamp = tick(),
            Importance = importance,
            TimesRecalled = 0,
            AssociatedEmotions = BotState.Emotions
        }
        
        -- Краткосрочная память
        table.insert(BotState.ShortTermMemory, 1, memory)
        if #BotState.ShortTermMemory > CONFIG.MEMORY.ShortTermCapacity then
            local oldMemory = table.remove(BotState.ShortTermMemory)
            -- Переносим важные в долгосрочную
            if oldMemory.Importance >= CONFIG.MEMORY.ImportanceThreshold then
                table.insert(BotState.LongTermMemory, 1, oldMemory)
                if #BotState.LongTermMemory > CONFIG.MEMORY.LongTermCapacity then
                    table.remove(BotState.LongTermMemory)
                end
            end
        end
        
        return memory
    end,
    
    -- Поиск похожих воспоминаний
    Recall = function(eventType, context)
        local matches = {}
        
        -- Ищем в обеих памятях
        local allMemories = {}
        for _, m in ipairs(BotState.ShortTermMemory) do
            table.insert(allMemories, m)
        end
        for _, m in ipairs(BotState.LongTermMemory) do
            table.insert(allMemories, m)
        end
        
        for _, memory in ipairs(allMemories) do
            if memory.Type == eventType then
                local relevance = memory.Importance * (1 + memory.TimesRecalled * 0.1)
                if context then
                    -- Проверка контекста (упрощённая)
                    relevance = relevance * 0.8
                end
                table.insert(matches, {Memory = memory, Relevance = relevance})
            end
        end
        
        -- Сортируем по релевантности
        table.sort(matches, function(a, b) return a.Relevance > b.Relevance end)
        
        -- Увеличиваем счётчик воспоминаний
        if #matches > 0 then
            matches[1].Memory.TimesRecalled = matches[1].Memory.TimesRecalled + 1
        end
        
        return matches
    end,
    
    -- Забывание неважного
    DecayMemories = function()
        for i = #BotState.ShortTermMemory, 1, -1 do
            BotState.ShortTermMemory[i].Importance = 
                BotState.ShortTermMemory[i].Importance - CONFIG.MEMORY.DecayRate
            if BotState.ShortTermMemory[i].Importance <= 0 then
                table.remove(BotState.ShortTermMemory, i)
            end
        end
    end
}

-- ===== СИСТЕМА ЭМОЦИЙ =====
local EmotionSystem = {
    -- Обновление эмоций
    Update = function(deltaTime)
        -- Затухание эмоций
        for emotion, value in pairs(BotState.Emotions) do
            if emotion ~= "Confidence" and emotion ~= "Suspicion" then
                BotState.Emotions[emotion] = math.max(0, value - CONFIG.EMOTIONS.DecayRate * deltaTime)
            end
        end
        
        -- Уверенность зависит от успехов
        local successRate = BotState.RoundsPlayed > 0 and 
            (BotState.KillCount / math.max(1, BotState.RoundsPlayed)) or 0.5
        BotState.Emotions.Confidence = math.clamp(
            successRate * 0.7 + CONFIG.PERSONALITY.Confidence * 0.3,
            0.1, 1.0
        )
    end,
    
    -- Триггер эмоции
    Trigger = function(emotion, intensity)
        BotState.Emotions[emotion] = math.min(
            CONFIG.EMOTIONS.MaxIntensity,
            BotState.Emotions[emotion] + intensity
        )
    },
    
    -- Получение доминирующей эмоции
    GetDominant = function()
        local dominant = "Neutral"
        local maxValue = 0
        
        for emotion, value in pairs(BotState.Emotions) do
            if value > maxValue and value > 0.3 then
                maxValue = value
                dominant = emotion
            end
        end
        
        return dominant, maxValue
    end
}

-- ===== СИСТЕМА ПРИНЯТИЯ РЕШЕНИЙ =====
local DecisionSystem = {
    -- Дерево решений
    Decide = function(role, context)
        local decisions = {}
        
        if role == "Innocent" then
            decisions = DecisionSystem.InnocentDecisions(context)
        elseif role == "Sheriff" then
            decisions = DecisionSystem.SheriffDecisions(context)
        elseif role == "Murderer" then
            decisions = DecisionSystem.MurdererDecisions(context)
        end
        
        -- Взвешиваем решения с учётом эмоций и личности
        for _, decision in ipairs(decisions) do
            decision.Weight = DecisionSystem.CalculateWeight(decision, context)
        end
        
        -- Сортируем
        table.sort(decisions, function(a, b) return a.Weight > b.Weight end)
        
        -- Добавляем элемент случайности (исследование vs эксплуатация)
        if math.random() < 0.15 then -- 15% случайного выбора
            return decisions[math.random(1, #decisions)]
        end
        
        return decisions[1]
    end,
    
    -- Решения для Innocent
    InnocentDecisions = function(context)
        local decisions = {
            {
                Name = "Flee",
                BaseWeight = context.DangerLevel * 0.9,
                Action = "RunAway"
            },
            {
                Name = "Hide",
                BaseWeight = context.DangerLevel * 0.7,
                Action = "SeekCover"
            },
            {
                Name = "GroupUp",
                BaseWeight = (1 - context.DangerLevel) * CONFIG.PERSONALITY.SocialBias * 0.6,
                Action = "FindGroup"
            },
            {
                Name = "Explore",
                BaseWeight = (1 - context.DangerLevel) * CONFIG.PERSONALITY.Curiosity * 0.5,
                Action = "Wander"
            },
            {
                Name = "CollectCoins",
                BaseWeight = (1 - context.DangerLevel) * 0.3,
                Action = "CollectCoins"
            },
            {
                Name = "Observe",
                BaseWeight = CONFIG.PERSONALITY.Patience * 0.4,
                Action = "Idle"
            },
            {
                Name = "FollowSomeone",
                BaseWeight = CONFIG.PERSONALITY.SocialBias * 0.35,
                Action = "FollowPlayer"
            }
        }
        
        return decisions
    end,
    
    -- Решения для Sheriff
    SheriffDecisions = function(context)
        local decisions = {
            {
                Name = "HuntMurderer",
                BaseWeight = 0.8,
                Action = "SeekMurderer"
            },
            {
                Name = "ProtectInnocents",
                BaseWeight = 0.6,
                Action = "GuardPlayers"
            },
            {
                Name = "Patrol",
                BaseWeight = 0.5,
                Action = "Patrol"
            },
            {
                Name = "GroupUp",
                BaseWeight = 0.3,
                Action = "FindGroup"
            }
        }
        
        return decisions
    end,
    
    -- Решения для Murderer
    MurdererDecisions = function(context)
        local decisions = {
            {
                Name = "HuntLonePlayer",
                BaseWeight = 0.7,
                Action = "FindLoneTarget"
            },
            {
                Name = "Ambush",
                BaseWeight = 0.5,
                Action = "SetupAmbush"
            },
            {
                Name = "BlendIn",
                BaseWeight = 0.4,
                Action = "ActInnocent"
            },
            {
                Name = "AvoidSheriff",
                BaseWeight = context.SheriffProximity * 0.9,
                Action = "AvoidSheriff"
            },
            {
                Name = "StalkGroup",
                BaseWeight = 0.3,
                Action = "StalkGroup"
            }
        }
        
        return decisions
    end,
    
    -- Расчёт веса решения
    CalculateWeight = function(decision, context)
        local weight = decision.BaseWeight
        
        -- Влияние эмоций
        local dominantEmotion, intensity = EmotionSystem.GetDominant()
        if dominantEmotion == "Fear" and decision.Name ~= "Flee" then
            weight = weight * (1 - intensity * 0.5)
        elseif dominantEmotion == "Anger" and decision.Name == "HuntMurderer" then
            weight = weight * (1 + intensity * 0.3)
        elseif dominantEmotion == "Confidence" and decision.Name == "Explore" then
            weight = weight * (1 + intensity * 0.2)
        end
        
        -- Влияние личности
        if CONFIG.PERSONALITY.Type == "Aggressive" and 
           (decision.Name == "HuntMurderer" or decision.Name == "HuntLonePlayer") then
            weight = weight * 1.3
        elseif CONFIG.PERSONALITY.Type == "Cautious" and decision.Name == "Flee" then
            weight = weight * 1.4
        end
        
        return weight
    end
}

-- ===== СИСТЕМА ВОСПРИЯТИЯ =====
local PerceptionSystem = {
    -- Сканирование окружения
    Scan = function()
        local perception = {
            NearbyPlayers = {},
            Threats = {},
            Allies = {},
            Items = {},
            CoverSpots = {},
            DeadBodies = {},
            SuspiciousActivity = {}
        }
        
        local root = getRoot()
        if not root then return perception end
        
        -- Сканирование игроков
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local playerRoot = player.Character:FindFirstChild("HumanoidRootPart")
                if playerRoot then
                    local distance = (root.Position - playerRoot.Position).Magnitude
                    
                    if distance <= CONFIG.PERCEPTION.VisionRadius then
                        local angle = PerceptionSystem.CalculateAngle(root, playerRoot.Position)
                        
                        if math.abs(angle) <= CONFIG.PERCEPTION.VisionAngle / 2 then
                            local playerInfo = {
                                Player = player,
                                Distance = distance,
                                Angle = angle,
                                Role = getPlayerRole(player),
                                IsMoving = isPlayerMoving(player),
                                LastSeen = tick(),
                                ThreatLevel = PerceptionSystem.AssessThreat(player, distance)
                            }
                            
                            table.insert(perception.NearbyPlayers, playerInfo)
                            
                            -- Классификация
                            if playerInfo.ThreatLevel > 0.6 then
                                table.insert(perception.Threats, playerInfo)
                            elseif playerInfo.ThreatLevel < 0.3 then
                                table.insert(perception.Allies, playerInfo)
                            end
                        end
                    end
                end
            end
        end
        
        -- Сканирование предметов (монеты, оружие)
        PerceptionSystem.ScanItems(perception, root)
        
        -- Поиск укрытий
        PerceptionSystem.FindCover(perception, root)
        
        return perception
    end,
    
    -- Расчёт угла обзора
    CalculateAngle = function(root, targetPos)
        local forward = root.CFrame.LookVector
        local toTarget = (targetPos - root.Position).Unit
        local angle = math.acos(math.clamp(forward:Dot(toTarget), -1, 1))
        return math.deg(angle)
    end,
    
    -- Оценка угрозы
    AssessThreat = function(player, distance)
        local threat = 0
        
        -- Базовая угроза от роли
        local role = getPlayerRole(player)
        if role == "Murderer" then
            threat = threat + 0.8
        elseif role == "Sheriff" and myRole() == "Murderer" then
            threat = threat + 0.9
        end
        
        -- Близость увеличивает угрозу
        threat = threat + (1 - math.min(distance / CONFIG.PERCEPTION.DangerRadius, 1)) * 0.4
        
        -- Память о предыдущих действиях
        if BotState.PlayerDatabase[player.Name] then
            local data = BotState.PlayerDatabase[player.Name]
            if data.SuspiciousActions and data.SuspiciousActions > 0 then
                threat = threat + data.SuspiciousActions * 0.1
            end
        end
        
        return math.clamp(threat, 0, 1)
    end,
    
    -- Сканирование предметов
    ScanItems = function(perception, root)
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("BasePart") then
                local dist = (root.Position - obj.Position).Magnitude
                
                if dist <= CONFIG.PERCEPTION.VisionRadius then
                    if obj.Name == "Coin" or obj.Name:lower():find("coin") then
                        table.insert(perception.Items, {
                            Object = obj,
                            Type = "Coin",
                            Distance = dist,
                            Position = obj.Position
                        })
                    end
                end
            elseif obj:IsA("Tool") then
                local dist = obj.Parent and obj.Parent:FindFirstChild("Handle") and 
                    (root.Position - obj.Parent.Handle.Position).Magnitude or 999
                
                if dist <= CONFIG.PERCEPTION.VisionRadius then
                    local weaponType = obj.Name:lower():find("gun") and "Gun" or 
                                      obj.Name:lower():find("knife") and "Knife" or "Unknown"
                    table.insert(perception.Items, {
                        Object = obj,
                        Type = weaponType,
                        Distance = dist,
                        Position = obj.Parent.Handle.Position
                    })
                end
            end
        end
    end,
    
    -- Поиск укрытий
    FindCover = function(perception, root)
        local coverPoints = {}
        local searchRadius = 30
        
        for x = -searchRadius, searchRadius, 5 do
            for z = -searchRadius, searchRadius, 5 do
                local point = root.Position + Vector3.new(x, 0, z)
                
                -- Проверка, является ли точка укрытием
                local rayParams = RaycastParams.new()
                rayParams.FilterType = Enum.RaycastFilterType.Blacklist
                rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
                
                local ray = Workspace:Raycast(point, Vector3.new(0, 10, 0), rayParams)
                if ray then
                    table.insert(perception.CoverSpots, {
                        Position = point,
                        Height = ray.Distance,
                        Quality = math.random() -- В реальности нужна оценка защиты
                    })
                end
            end
        end
    end
}

-- ===== УЛУЧШЕННАЯ СИСТЕМА ДВИЖЕНИЯ =====
local MovementSystem = {
    -- Плавное движение к точке
    SmoothMove = function(targetPos, speed, options)
        options = options or {}
        local root = getRoot()
        local humanoid = getHumanoid()
        if not root or not humanoid then return false end
        
        humanoid.WalkSpeed = speed or CONFIG.MOVEMENT.WalkSpeed
        
        -- Проверка прямой видимости
        local canSeeTarget = MovementSystem.HasLineOfSight(root.Position, targetPos)
        
        if canSeeTarget then
            -- Прямое движение с плавным поворотом
            MovementSystem.SmoothTurn(targetPos, CONFIG.MOVEMENT.TurnRadius)
            humanoid:MoveTo(targetPos)
            
            -- Проверка достижения
            local dist = (root.Position - targetPos).Magnitude
            return dist <= CONFIG.MOVEMENT.StoppingDistance
        else
            -- Pathfinding
            return MovementSystem.PathfindMove(targetPos, speed)
        end
    end,
    
    -- Pathfinding с улучшениями
    PathfindMove = function(targetPos, speed)
        local root = getRoot()
        local humanoid = getHumanoid()
        if not root or not humanoid then return false end
        
        local path = PathfindingService:CreatePath({
            AgentRadius = 2,
            AgentHeight = 5,
            AgentCanJump = true,
            AgentMaxSlope = 55,
            WaypointSpacing = 3,
            Costs = {
                Water = 30,
                DangerZone = math.huge
            }
        })
        
        local success = pcall(function()
            path:ComputeAsync(root.Position, targetPos)
        end)
        
        if success and path.Status == Enum.PathStatus.Success then
            local waypoints = path:GetWaypoints()
            
            for _, waypoint in ipairs(waypoints) do
                if waypoint.Action == Enum.PathWaypointAction.Jump then
                    humanoid.Jump = true
                end
                
                MovementSystem.SmoothTurn(waypoint.Position, CONFIG.MOVEMENT.TurnRadius * 0.5)
                humanoid:MoveTo(waypoint.Position)
                
                -- Ожидание с проверкой застревания
                local waitTime = 0
                while waitTime < 3 do
                    task.wait(0.1)
                    waitTime = waitTime + 0.1
                    
                    if (root.Position - waypoint.Position).Magnitude < CONFIG.MOVEMENT.StoppingDistance then
                        break
                    end
                    
                    -- Анти-застревание
                    if MovementSystem.IsStuck() then
                        humanoid.Jump = true
                        task.wait(0.2)
                    end
                end
            end
            return true
        end
        
        return false
    end,
    
    -- Плавный поворот
    SmoothTurn = function(lookPos, duration)
        local root = getRoot()
        if not root then return end
        
        local lookDir = (lookPos - root.Position) * Vector3.new(1,0,1)
        if lookDir.Magnitude < 0.1 then return end
        
        local targetCFrame = CFrame.new(root.Position, root.Position + lookDir.Unit)
        
        local tween = TweenService:Create(root,
            TweenInfo.new(duration or CONFIG.MOVEMENT.TurnRadius,
                Enum.EasingStyle.Quad,
                Enum.EasingDirection.Out),
            {CFrame = targetCFrame}
        )
        tween:Play()
        tween.Completed:Wait()
    end,
    
    -- Проверка прямой видимости
    HasLineOfSight = function(from, to)
        local rayParams = RaycastParams.new()
        rayParams.FilterType = Enum.RaycastFilterType.Blacklist
        rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
        
        local direction = (to - from)
        local ray = Workspace:Raycast(from, direction, rayParams)
        
        return not ray or ray.Position == to
    end,
    
    -- Проверка застревания
    IsStuck = function()
        local root = getRoot()
        if not root then return false end
        
        local movement = (root.Position - BotState.LastPosition).Magnitude
        BotState.LastPosition = root.Position
        
        if movement < 0.5 then
            BotState.StuckTime = BotState.StuckTime + 0.1
            return BotState.StuckTime > 1.5
        else
            BotState.StuckTime = 0
            return false
        end
    end,
    
    -- Человеческие движения камеры
    HumanCameraMovement = function()
        if not UserInputService.MouseEnabled then return end
        
        local camera = Workspace.CurrentCamera
        if not camera then return end
        
        -- Микродвижения мыши
        local microX = math.random(-2, 2) * 0.1
        local microY = math.random(-1, 1) * 0.1
        
        camera.CFrame = camera.CFrame * 
            CFrame.Angles(math.rad(microY), math.rad(microX), 0) *
            CFrame.new(math.random(-1,1)*0.01, math.random(-1,1)*0.01, 0)
    end
}

