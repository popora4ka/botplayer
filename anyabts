    InnocentBehavior = function(perception)
        local context = {
            DangerLevel = #perception.Threats > 0 and 0.8 or 0.1,
            SheriffProximity = 0,
            HasAllies = #perception.Allies > 0,
            NearbyPlayers = #perception.NearbyPlayers
        }
        
        local decision = DecisionSystem.Decide("Innocent", context)
        BehaviorSystem.ExecuteAction(decision.Action, perception)
    end,
    
    -- Sheriff поведение
    SheriffBehavior = function(perception)
        local context = {
            DangerLevel = 0.3,
            SheriffProximity = 0,
            HasAllies = true,
            NearbyPlayers = #perception.NearbyPlayers
        }
        
        local decision = DecisionSystem.Decide("Sheriff", context)
        BehaviorSystem.ExecuteAction(decision.Action, perception)
    end,
    -- Murderer поведение
    MurdererBehavior = function(perception)
        local context = {
            DangerLevel = 0.4,
            SheriffProximity = BehaviorSystem.GetSheriffProximity(perception),
            HasAllies = false,
            NearbyPlayers = #perception.NearbyPlayers
        }
        
        local decision = DecisionSystem.Decide("Murderer", context)
        BehaviorSystem.ExecuteAction(decision.Action, perception)
    end,
    
    -- Выполнение действия
    ExecuteAction = function(action, perception)
        BotState.CurrentBehavior = action
        
        if action == "RunAway" then
            BehaviorSystem.RunAway(perception)
        elseif action == "SeekCover" then
            BehaviorSystem.SeekCover(perception)
        elseif action == "FindGroup" then
            BehaviorSystem.FindGroup(perception)
        elseif action == "Wander" then
            BehaviorSystem.Wander(perception)
        elseif action == "CollectCoins" then
            BehaviorSystem.CollectCoins(perception)
        elseif action == "Idle" then
            BehaviorSystem.Idle(perception)
        elseif action == "FollowPlayer" then
            BehaviorSystem.FollowPlayer(perception)
        elseif action == "SeekMurderer" then
            BehaviorSystem.SeekMurderer(perception)
        elseif action == "FindLoneTarget" then
            BehaviorSystem.FindLoneTarget(perception)
        elseif action == "ActInnocent" then
            BehaviorSystem.ActInnocent(perception)
        end
    end,
    
    -- Убегание
    RunAway = function(perception)
        if #perception.Threats == 0 then return end
        
        local root = getRoot()
        if not root then return end
        
        local threat = perception.Threats[1]
        local escapeDir = (root.Position - threat.Player.Character.HumanoidRootPart.Position).Unit
        local escapePos = root.Position + escapeDir * 70
        
        MovementSystem.PathfindMove(escapePos, CONFIG.MOVEMENT.RunSpeed)
        EmotionSystem.Trigger("Fear", 0.3)
    end,
    
    -- Поиск укрытия
    SeekCover = function(perception)
        if #perception.CoverSpots == 0 then
            BehaviorSystem.RunAway(perception)
            return
        end
        
        local root = getRoot()
        if not root then return end
        
        table.sort(perception.CoverSpots, function(a, b)
            return (root.Position - a.Position).Magnitude < (root.Position - b.Position).Magnitude
        end)
        
        MovementSystem.PathfindMove(perception.CoverSpots[1].Position, CONFIG.MOVEMENT.RunSpeed)
    end,
    
    -- Присоединение к группе
    FindGroup = function(perception)
        if #perception.Allies < 2 then
            BehaviorSystem.Wander(perception)
            return
        end
        
        -- Ищем центр группы
        local center = Vector3.zero
        for _, ally in ipairs(perception.Allies) do
            center = center + ally.Player.Character.HumanoidRootPart.Position
        end
        center = center / #perception.Allies
        
        MovementSystem.PathfindMove(center, CONFIG.MOVEMENT.WalkSpeed)
    end,
    
    -- Блуждание
    Wander = function(perception)
        local root = getRoot()
        if not root then return end
        
        local wanderTarget = root.Position + Vector3.new(
            math.random(-50, 50),
            0,
            math.random(-50, 50)
        )
        
        MovementSystem.PathfindMove(wanderTarget, CONFIG.MOVEMENT.WalkSpeed)
    end,
    
    -- Сбор монет
    CollectCoins = function(perception)
        local coins = {}
        for _, item in ipairs(perception.Items) do
            if item.Type == "Coin" then
                table.insert(coins, item)
            end
        end
        
        if #coins == 0 then
            BehaviorSystem.Wander(perception)
            return
        end
        
        table.sort(coins, function(a, b) return a.Distance < b.Distance end)
        MovementSystem.PathfindMove(coins[1].Position, CONFIG.MOVEMENT.WalkSpeed)
    end,
    
    -- Бездействие (реалистичное)
    Idle = function(perception)
        local humanoid = getHumanoid()
        local root = getRoot()
        if not humanoid or not root then return end
        
        humanoid:MoveTo(root.Position)
        
        local idleTime = math.random(1, 4)
        local startTime = tick()
        
        while tick() - startTime < idleTime do
            -- Естественные движения камеры
            MovementSystem.HumanCameraMovement()
            
            -- Иногда осматриваемся
            if math.random() < 0.3 then
                local lookPos = root.Position + Vector3.new(
                    math.random(-20, 20),
                    0,
                    math.random(-20, 20)
                )
                MovementSystem.SmoothTurn(lookPos, 0.5)
            end
            
            task.wait(0.5)
        end
    end,
    
    -- Следование за игроком
    FollowPlayer = function(perception)
        if #perception.Allies == 0 then
            BehaviorSystem.Wander(perception)
            return
        end
        
        local target = perception.Allies[math.random(1, math.min(3, #perception.Allies))]
        local followDistance = CONFIG.SOCIAL.GroupFollowDistance[1] + 
            math.random() * (CONFIG.SOCIAL.GroupFollowDistance[2] - CONFIG.SOCIAL.GroupFollowDistance[1])
        
        local targetRoot = target.Player.Character.HumanoidRootPart
        local direction = (getRoot().Position - targetRoot.Position).Unit
        local followPos = targetRoot.Position + direction * followDistance
        
        MovementSystem.PathfindMove(followPos, CONFIG.MOVEMENT.WalkSpeed)
    end,
    
    -- Поиск murderer (для sheriff)
    SeekMurderer = function(perception)
        local murderers = {}
        for _, player in ipairs(perception.NearbyPlayers) do
            if player.Role == "Murderer" then
                table.insert(murderers, player)
            end
        end
        
        if #murderers > 0 then
            local target = murderers[1]
            MovementSystem.PathfindMove(
                target.Player.Character.HumanoidRootPart.Position,
                CONFIG.MOVEMENT.RunSpeed
            )

            -- Атака если близко
            if target.Distance <= CONFIG.COMBAT.AimTime[2] * CONFIG.MOVEMENT.RunSpeed then
                BehaviorSystem.ShootTarget(target.Player)
            end
        else
            BehaviorSystem.Wander(perception)
        end
    end,
    
    -- Поиск одинокой цели (для murderer)
    FindLoneTarget = function(perception)
        local lonePlayers = {}
        
        for _, player in ipairs(perception.NearbyPlayers) do
            if player.Role ~= "Murderer" and player.Distance < 30 then
                -- Проверяем, один ли игрок
                local hasNearbyAllies = false
                for _, other in ipairs(perception.NearbyPlayers) do
                    if other ~= player and other.Role ~= "Murderer" then
                        local otherRoot = other.Player.Character.HumanoidRootPart
                        local playerRoot = player.Player.Character.HumanoidRootPart
                        if (otherRoot.Position - playerRoot.Position).Magnitude < 15 then
                            hasNearbyAllies = true
                            break
                        end
                    end
                end
                
                if not hasNearbyAllies then
                    table.insert(lonePlayers, player)
                end
            end
        end
        
        if #lonePlayers > 0 then
            local target = lonePlayers[1]
            MovementSystem.PathfindMove(
                target.Player.Character.HumanoidRootPart.Position,
                CONFIG.MOVEMENT.SneakSpeed
            )
            
            -- Атака вблизи
            if target.Distance <= 5 then
                BehaviorSystem.KnifeAttack(target.Player)
            end
        else
            BehaviorSystem.ActInnocent(perception)
        end
    end,
    
    -- Притворство innoccent (для murderer)
    ActInnocent = function(perception)
        local behaviors = {"Wander", "Idle", "FollowPlayer", "CollectCoins"}
        local chosen = behaviors[math.random(1, #behaviors)]
        BehaviorSystem.ExecuteAction(chosen, perception)
    end,
    
    -- Стрельба
    ShootTarget = function(target)
        equipWeapon("gun")
        local targetRoot = target.Character.HumanoidRootPart
        
        -- Прицеливание с учётом точности
        local aimTime = math.random(CONFIG.COMBAT.AimTime[1]*100, CONFIG.COMBAT.AimTime[2]*100)/100
        MovementSystem.SmoothTurn(targetRoot.Position, aimTime)
        
        -- Разброс
        if math.random() > CONFIG.COMBAT.AimAccuracy then
            local missAngle = Vector3.new(
                math.random(-5, 5),
                math.random(-3, 3),
                math.random(-5, 5)
            )
            targetRoot = targetRoot.Position + missAngle
        end
        
        task.wait(aimTime)
        attack()
        BotState.LastAttackTime = tick()
    end,
    
    -- Атака ножом
    KnifeAttack = function(target)
        equipWeapon("knife")
        MovementSystem.SmoothTurn(
            target.Character.HumanoidRootPart.Position,
            0.2
        )
        attack()
        BotState.LastAttackTime = tick()
        BotState.KillCount = BotState.KillCount + 1
    end,
    
    -- Получение близости шерифа
    GetSheriffProximity = function(perception)
        for _, player in ipairs(perception.NearbyPlayers) do
            if player.Role == "Sheriff" then
                return math.max(0, 1 - player.Distance / CONFIG.PERCEPTION.DangerRadius)
            end
        end
        return 0
    end
}

-- ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
local function getRoot()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("Humanoid")
end

local function isAlive(player)
    local char = player.Character
    if not char then return false end
    local humanoid = char:FindFirstChild("Humanoid")
    return humanoid and humanoid.Health > 0
end

local function getPlayerRole(player)
    if not player.Character then return nil end
    for _, tool in ipairs(player.Character:GetChildren()) do
        if tool:IsA("Tool") then
            local n = tool.Name:lower()
            if n:find("knife") or n:find("blade") then return "Murderer"
            elseif n:find("gun") or n:find("pistol") or n:find("sheriff") then return "Sheriff"
            end
        end
    end
    return "Innocent"
end

local function myRole()
    local char = LocalPlayer.Character
    if not char then return nil end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            local n = tool.Name:lower()
            if n:find("knife") then return "Murderer"
            elseif n:find("gun") or n:find("pistol") then return "Sheriff"
            end
        end
    end
    return "Innocent"
end

local function isPlayerMoving(player)
    if not player.Character then return false end
    local humanoid = player.Character:FindFirstChild("Humanoid")
    return humanoid and humanoid.MoveDirection.Magnitude > 0.1
end

local function equipWeapon(name)
    local char = LocalPlayer.Character
    if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:lower():find(name) then
            getHumanoid():EquipTool(tool)
            return
        end
    end
end

local function attack()
    local char = LocalPlayer.Character
    if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            local n = tool.Name:lower()
            if n:find("knife") or n:find("gun") then
                if tool:FindFirstChild("RemoteEvent") then
                    tool.RemoteEvent:FireServer()
                else
                    tool:Activate()
                end
                return
            end
        end
    end
end

-- ===== ГЛАВНЫЙ ЦИКЛ =====
local function MainLoop()
    local lastPerceptionUpdate = 0
    local perception = nil
    
    while BotState.IsActive do
        local deltaTime = tick() - lastPerceptionUpdate
        lastPerceptionUpdate = tick()
        
        -- Проверка жизни
        if not isAlive(LocalPlayer) then
            BotState.IsAlive = false
            task.wait(1)
            continue
        end
        BotState.IsAlive = true
        
        -- Определение роли
        BotState.CurrentRole = myRole()
        
        -- Обновление восприятия
        perception = PerceptionSystem.Scan()
        
        -- Обновление эмоций
        EmotionSystem.Update(deltaTime)
        
        -- Декей памяти
        if math.random() < 0.1 then
            MemorySystem.DecayMemories()
        end
        
        -- Выполнение поведения в зависимости от роли
        if BotState.CurrentRole == "Innocent" then
            BehaviorSystem.InnocentBehavior(perception)
        elseif BotState.CurrentRole == "Sheriff" then
            BehaviorSystem.SheriffBehavior(perception)
        elseif BotState.CurrentRole == "Murderer" then
            BehaviorSystem.MurdererBehavior(perception)
        end
        
        -- Естественные движения камеры
        MovementSystem.HumanCameraMovement()
        
        -- Анти-застревание
        if MovementSystem.IsStuck() then
            local humanoid = getHumanoid()
            if humanoid then
                humanoid.Jump = true
            end
        end
        
        -- Сохранение позиции
        local root = getRoot()
        if root then
            BotState.Position = root.Position
        end
        
        task.wait(CONFIG.PERCEPTION.UpdateFrequency)
    end
end

