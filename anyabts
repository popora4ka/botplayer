-- ===== VISUAL WEAPONS =====
local function ChangeWeaponVisual(from, to)
    if not from or from == "" or not to or to == "" then
        Window:Notify({
            Title = "Error",
            Content = "Please enter both weapon names!",
            Icon = "x-circle",
            Duration = 3
        })
        return
    end
    
    local success, itemDB = pcall(function()
        return require(game:GetService("ReplicatedStorage").Database.Sync.Item)
    end)
    
    if not success or not itemDB then
        Window:Notify({
            Title = "Error",
            Content = "Could not access item database!",
            Icon = "x-circle",
            Duration = 3
        })
        return
    end
    
    local fromList = {}
    local toList = {}
    
    for name, data in pairs(itemDB) do
        if name:lower():find(from:lower(), 1, true) then
            table.insert(fromList, name)
        end
        if name:lower():find(to:lower(), 1, true) then
            table.insert(toList, name)
        end
    end
    
    if #fromList == 0 or #toList == 0 then
        Window:Notify({
            Title = "Error",
            Content = "Weapon(s) not found!",
            Icon = "x-circle",
            Duration = 3
        })
        return
    end
    
    for _, fromName in ipairs(fromList) do
        for _, toName in ipairs(toList) do
            itemDB[fromName] = {}
            for key, value in pairs(itemDB[toName]) do
                itemDB[fromName][key] = value
            end
        end
    end
    
    Window:Notify({
        Title = "Visual Change Complete",
        Content = "Weapon visual changed!",
        Icon = "check-circle",
        Duration = 3
    })
end

