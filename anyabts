    local votingGui = LocalPlayer.PlayerGui:FindFirstChild("VotingGui") or 
                     LocalPlayer.PlayerGui:FindFirstChild("VoteGui") or
                     LocalPlayer.PlayerGui:FindFirstChild("MapVote")
    
    if votingGui then
        for _, child in ipairs(votingGui:GetDescendants()) do
            if child:IsA("TextButton") and child.Text:lower():find(mapName:lower()) then
                -- Активация кнопки
