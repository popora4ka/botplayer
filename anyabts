local function spawnWeapon(weaponName)
    if not weaponName or weaponName == "" then
        notify("Ошибка", "Введите название оружия!")
        return
    end
    
    pcall(function()
        local DataBase = require(ReplicatedStorage.Database.Sync.Item)
        local ProfileData = require(ReplicatedStorage.Modules.ProfileData)
        local weapons = ProfileData.Weapons
        
        if not weapons.Owned[weaponName] then
            weapons.Owned[weaponName] = 1
        else
            weapons.Owned[weaponName] = weapons.Owned[weaponName] + 1
        end
        
        RunService:BindToRenderStep("InventoryUpdate", 0, function()
            ProfileData.Weapons = weapons
        end)
        
        local char = getCharacter()
        if char then
            char:BreakJoints()
        end
        
        notify("Оружие", weaponName .. " успешно создано!", 3)
    end)
end

