-- 11. KILL ALL (убить всех) (из script5)
-- ═══════════════════════════════════════════════════════════════
local function killAll()
    local char = getCharacter()
    if not char then return end
    local knife = char:FindFirstChild("Knife")
    if not knife then
        notify("Ошибка", "У вас нет ножа!")
        return
    end
    
    local alive = getAlivePlayers()
    if #alive == 0 then
        notify("Kill All", "Нет живых игроков")
        return
    end
    
    for _, p in ipairs(alive) do
        local rootPart = p.Character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            local playerRoot = getRoot()
            if playerRoot then
                playerRoot.CFrame = rootPart.CFrame * CFrame.new(0, 0, -2)
                knife:Activate()
                task.wait(0.1)
            end
        end
    end
    notify("Kill All", "Все убиты!", 3)
end

