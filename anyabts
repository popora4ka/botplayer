local function CollectCoin()
    if not (autoCoin or autoCandy) or not roundActive or flingingMurderer or undergroundFarm then return end
    
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local target, dist
    
    if autoCandy then
        target, dist = GetClosestCandy()
    else
        target, dist = GetClosestCoin()
    end
    
    if target then
        if dist > 150 then
            root.CFrame = target.CFrame
        else
            local tween = TweenService:Create(root, TweenInfo.new(dist / farmSpeed, Enum.EasingStyle.Linear), {
                CFrame = target.CFrame
            })
            tween:Play()
            task.wait(dist / farmSpeed)
            tween:Cancel()
        end
        collectedCount = collectedCount + 1
    end
end

-- ===== FLING FUNCTIONS =====
local function FlingMurderer()
    if flingingMurderer then return end
    flingingMurderer = true
    
    local murderer = nil
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            if player.Character:FindFirstChild("Knife") then
                murderer = player
                break
            end
            local backpack = player:FindFirstChild("Backpack")
            if backpack and backpack:FindFirstChild("Knife") then
                murderer = player
                break
            end
        end
    end
    
    if not murderer or not murderer.Character then
        Window:Notify({
            Title = "Fling Error",
            Content = "No murderer found!",
            Icon = "x-circle",
            Duration = 3
        })
        flingingMurderer = false
        return
    end
    
    Window:Notify({
        Title = "Flinging Murderer",
        Content = "Flinging " .. murderer.Name .. "!",
        Icon = "zap",
        Duration = 3
    })
    
    local target = murderer.Character
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
local targetRoot = target:FindFirstChild("HumanoidRootPart")
    local humanoid = target:FindFirstChildOfClass("Humanoid")
    
    if root and targetRoot and humanoid then
        local bodyVel = Instance.new("BodyVelocity")
        bodyVel.Name = "WolokoFling"
        bodyVel.Parent = targetRoot
        bodyVel.Velocity = Vector3.new(90000000, 90000000, 90000000)
        bodyVel.MaxForce = Vector3.new(1/0, 1/0, 1/0)
        
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
        
        for i = 1, 10 do
            targetRoot.CFrame = CFrame.new(targetRoot.Position) * CFrame.Angles(math.rad(i * 36), 0, 0)
            task.wait(0.05)
        end
        
        bodyVel:Destroy()
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, true)
    end
    
    Window:Notify({
        Title = "Fling Complete",
        Content = "Murderer has been flung!",
        Icon = "check-circle",
        Duration = 2
    })
    
    flingingMurderer = false
end

-- ===== KILL FUNCTIONS =====
local function GetNearestTarget()
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    
    local targets = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
            local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
            if humanoid and humanoid.Health > 0 and targetRoot then
                table.insert(targets, {
                    Player = player,
                    Distance = (root.Position - targetRoot.Position).Magnitude,
                    Root = targetRoot
                })
            end
        end
    end
    
    table.sort(targets, function(a, b) return a.Distance < b.Distance end)
    return targets[1]
end

local function KillNearest()
    if not killAllActive then return end
    
    local target = GetNearestTarget()
    if not target then return end
    
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    root.CFrame = CFrame.new(target.Root.Position + Vector3.new(0, 2, 0), target.Root.Position)
    task.wait(0.1)
    
    local knife = LocalPlayer.Character:FindFirstChild("Knife")
    if not knife then
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if backpack then
            knife = backpack:FindFirstChild("Knife")
            if knife then knife.Parent = LocalPlayer.Character end
        end
    end
    
    if knife and knife:FindFirstChild("Stab") then
        for i = 1, 3 do
            knife.Stab:FireServer("Down")
            task.wait(0.1)
        end
    end
end

-- ===== WEAPON SPAWN =====
local function SpawnWeapon(weaponName)
    if not weaponName or weaponName == "" then
        Window:Notify({
            Title = "Error",
            Content = "Please enter a weapon name!",
            Icon = "x-circle",
            Duration = 3
        })
        return
    end
    
    local inventory = nil
    if LocalPlayer.PlayerGui.MainGUI.Game:FindFirstChild("Inventory") == nil then
        inventory = LocalPlayer.PlayerGui.MainGUI.Lobby.Screens.Inventory.Main
    else
        inventory = LocalPlayer.PlayerGui.MainGUI.Game.Inventory.Main
    end
    
    if not inventory then
        Window:Notify({
            Title = "Error",
            Content = "Could not find inventory!",
            Icon = "x-circle",
            Duration = 3
        })
        return
    end
    
    local found = false
    for _, category in ipairs(inventory.Weapons.Items.Container:GetChildren()) do
        for _, item in ipairs(category.Container:GetChildren()) do
            if item.Name == "Christmas" or item.Name == "Halloween" then
                for _, weapon in ipairs(item.Container:GetChildren()) do
                    if weapon:IsA("Frame") and weapon.ItemName.Label.Text == weaponName then
                        found = true
                        local amount = weapon.Container.Amount.Text
                        if amount == "" or amount == "None" then
                            weapon.Container.Amount.Text = "x1"
                        else
                            local num = tonumber(amount:match("x(%d+)"))
                            if num then
                                weapon.Container.Amount.Text = "x" .. tostring(num + 1)
                            end
                        end
                    end
                end
            end
        end
    end
    
    if found then
        Window:Notify({
            Title = "Weapon Spawned",
            Content = "Successfully spawned: " .. weaponName,
            Icon = "check-circle",
            Duration = 3
        })
    else
        Window:Notify({
            Title = "Error",
            Content = "Weapon not found: " .. weaponName,
            Icon = "x-circle",
            Duration = 3
        })
    end
end

