local function getChar()
    return LP.Character or LP.CharacterAdded:Wait()
end

local function getHum()
    local char = getChar()
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function getRoot()
    local char = getChar()
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function hasTool(player, toolName)
    if not player then return false end
    if player.Character and player.Character:FindFirstChild(toolName) then
        return true
    end
    if player.Backpack and player.Backpack:FindFirstChild(toolName) then
        return true
    end
    return false
end

local function isMurderer(player)
    return hasTool(player, "Knife")
end

local function isSheriff(player)
    return hasTool(player, "Gun")
end

local function getMurderer()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and isMurderer(p) and p.Character then
            return p
        end
    end
    return nil
end

local function getSheriff()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and isSheriff(p) and p.Character then
            return p
        end
    end
    return nil
end

local function getAlivePlayers()
    local alive = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                table.insert(alive, p)
            end
        end
    end
    return alive
end

local function notify(title, text, duration)
    duration = duration or 3
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = duration
        })
    end)
end

local function spawnWeapon(name)
    if not name or name == "" then
        notify("Ошибка", "Введите название оружия!")
        return
    end
    pcall(function()
        local DataBase = require(ReplicatedStorage.Database.Sync.Item)
        local ProfileData = require(ReplicatedStorage.Modules.ProfileData)
        local weapons = ProfileData.Weapons
        if not weapons.Owned[name] then
            weapons.Owned[name] = 1
        else
            weapons.Owned[name] = weapons.Owned[name] + 1
        end
        RunService:BindToRenderStep("InventoryUpdate", 0, function()
            ProfileData.Weapons = weapons
        end)
        local char = getChar()
        if char then char:BreakJoints() end
        notify("Оружие", name .. " создано!", 3)
    end)
end

