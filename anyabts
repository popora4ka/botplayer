local function JumpOverObstacle(obstacle)
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("Humanoid") then return end
    
    local humanoid = character.Humanoid
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    -- Определяем высоту препятствия
    local obstacleHeight = obstacle.Size.Y
    local obstaclePos = obstacle.Position
    
    -- Подходим к препятствию
    MoveToPosition(Vector3.new(obstaclePos.X, rootPart.Position.Y, obstaclePos.Z))
    wait(0.5)
    
    -- Прыжок
    humanoid.Jump = true
    
    -- Если высокое, делаем двойной прыжок
    if obstacleHeight > 4 then
        wait(0.3)
        humanoid.Jump = true
    end
    
    return true
end

local function EscapeFromMurderer()
    local murderer = FindMurderer()
    if not murderer or not murderer.Character then return end
    
    local localChar = LocalPlayer.Character
    if not localChar or not localChar:FindFirstChild("HumanoidRootPart") then return end
    
    local murdererRoot = murderer.Character:FindFirstChild("HumanoidRootPart")
    if not murdererRoot then return end
    
    local distance = (localChar.HumanoidRootPart.Position - murdererRoot.Position).Magnitude
    
    -- Если мардер близко, убегаем
    if distance < 30 then
        local escapeDirection = (localChar.HumanoidRootPart.Position - murdererRoot.Position).Unit
        local escapePosition = localChar.HumanoidRootPart.Position + escapeDirection * 50
        
        -- Находим ближайшее укрытие
        local bestEscape = escapePosition
        local obstacles = {}
        
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Size.Magnitude > 5 and obj.Transparency < 0.5 then
                table.insert(obstacles, obj)
            end
        end
        
        if #obstacles > 0 then
            -- Выбираем самое дальнее от мардера укрытие
            local maxDist = 0
            for _, obs in ipairs(obstacles) do
                local dist = (obs.Position - murdererRoot.Position).Magnitude
                if dist > maxDist then
                    maxDist = dist
                    bestEscape = obs.Position
                end
            end
        end
        
        TweenToPosition(bestEscape, Bot.WalkSpeed * 1.5)
        return true
    end
    
    return false
end

local function CollectNearestCoins()
    if not Bot.CollectCoins then return end
    
    local coin = GetNearestCoin()
    if coin then
        CollectCoin(coin)
        return true
    end
    return false
end

local function CheckAndPassObstacles()
    if not Bot.AutoPassObstacles then return end
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    local rootPart = character.HumanoidRootPart
    local rayLength = 5
    
    -- Проверка препятствия впереди
    local rayOrigin = rootPart.Position
    local rayDirection = rootPart.CFrame.LookVector * rayLength
    
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {character}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    
    local raycastResult = Workspace:Raycast(rayOrigin, rayDirection, raycastParams)
    
    if raycastResult and raycastResult.Instance then
        local obstacle = raycastResult.Instance
        if obstacle:IsA("BasePart") and obstacle.Size.Y > 2 then
            JumpOverObstacle(obstacle)
            return true
        end
    end
    
    return false
end

