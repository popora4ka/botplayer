local farmLoop = nil
local lastCoin = nil

local function getCoins()
    local coins = {}
    for _, container in ipairs(Workspace:GetDescendants()) do
        if container:IsA("Model") and container.Name == "CoinContainer" then
            for _, coinServer in ipairs(container:GetChildren()) do
                if coinServer.Name == "Coin_Server" then
                    local coinVisual = coinServer:FindFirstChild("CoinVisual")
                    if coinVisual then
                        local mainCoin = coinVisual:FindFirstChild("MainCoin")
                        if mainCoin and mainCoin:IsA("MeshPart") then
                            table.insert(coins, mainCoin)
                        end
                    end
                end
            end
        end
    end
    return coins
end

local function teleportToCoin()
    local coins = getCoins()
    if #coins == 0 then return end
    local idx = math.random(1, #coins)
    local target = coins[idx]
    if target == lastCoin then
        idx = (idx % #coins) + 1
        target = coins[idx]
    end
    lastCoin = target
    local root = getRoot()
    if not root then return end
    local mode = _G.Woloko.FarmMode
    local offset = _G.Woloko.FarmOffset
    if mode == "Teleport above" then
        root.CFrame = target.CFrame + Vector3.new(0, offset, 0)
    elseif mode == "Teleport under" then
        root.CFrame = target.CFrame - Vector3.new(0, offset, 0)
    else
        root.CFrame = target.CFrame + Vector3.new(0, 3, 0)
    end
end

local function startFarm()
    if farmLoop then return end
    _G.Woloko.AutoFarm = true
    farmLoop = task.spawn(function()
        while _G.Woloko.AutoFarm do
            teleportToCoin()
            task.wait(_G.Woloko.FarmDelay)
        end
    end)
end

local function stopFarm()
    _G.Woloko.AutoFarm = false
    if farmLoop then
        task.cancel(farmLoop)
        farmLoop = nil
    end
end

