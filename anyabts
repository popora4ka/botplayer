local function CreateESP(target, color, name)
    if not Bot.ESPEnabled then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "BotESP_" .. name
    highlight.FillColor = color
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Color3.new(1, 1, 1)
    highlight.OutlineTransparency = 0
    highlight.Parent = target
    
    table.insert(Bot.EspObjects, highlight)
    return highlight
end

local function ClearESP()
    for _, obj in ipairs(Bot.EspObjects) do
        if obj and obj.Parent then
            obj:Destroy()
        end
    end
    Bot.EspObjects = {}
end

local function UpdateESP()
    ClearESP()
    
    local gameInfo = GetGameInfo()
    
    -- ESP для игроков
    if Bot.PlayerESP then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local color
                if player == gameInfo.Murderer then
                    color = Color3.new(1, 0, 0) -- Красный для мардера
                elseif player == gameInfo.Sheriff then
                    color = Color3.new(0, 0, 1) -- Синий для шерифа
                else
                    color = Color3.new(0, 1, 0) -- Зеленый для невинных
                end
                CreateESP(player.Character, color, player.Name)
            end
        end
    end
    
    -- ESP для оружия
    if Bot.GunESP then
        local gun = FindGun()
        if gun then
            CreateESP(gun, Color3.new(1, 1, 0), "SheriffGun")
        end
    end
    
    -- ESP для монет
    if Bot.CoinESP then
        for _, coin in ipairs(gameInfo.Coins) do
            CreateESP(coin, Color3.new(1, 1, 0), "Coin")
        end
    end
end

