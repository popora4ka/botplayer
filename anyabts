local function GetUndergroundTargets()
    local targets = {}
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return targets end
    
    for _, child in ipairs(Workspace:GetChildren()) do
        if child:FindFirstChild("CoinContainer") then
            for _, coin in ipairs(child.CoinContainer:GetChildren()) do
                if coin:IsA("BasePart") and coin:FindFirstChild("TouchInterest") then
                    if undergroundMode == "Coins" then
                        table.insert(targets, coin)
                    elseif undergroundMode == "Candy" and coin:GetAttribute("CoinID") == "Candy" then
                        table.insert(targets, coin)
                    end
                end
            end
        end
    end
    
    if undergroundMode == "Candy" then
        for _, descendant in ipairs(Workspace:GetDescendants()) do
            if descendant:IsA("BasePart") and descendant.Name == "candy" and descendant:FindFirstChild("TouchInterest") then
                table.insert(targets, descendant)
            end
        end
    end
    
    return targets
end

local function GetClosestUndergroundTarget()
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return nil, math.huge end
    
    local targets = GetUndergroundTargets()
    local closest = nil
    local closestDist = math.huge
    
    for _, target in ipairs(targets) do
        if target and target:IsA("BasePart") then
            local dist = (root.Position - target.Position).Magnitude
            if dist < closestDist then
                closest = target
                closestDist = dist
            end
        end
    end
    
    return closest, closestDist
end

local function TeleportUnderground()
    if not undergroundFarm then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not root or not humanoid then return end
    
    -- Проваливаемся под карту
    local underPos = root.Position + Vector3.new(0, undergroundLayer, 0)
    root.CFrame = CFrame.new(underPos)
    
    -- Ложимся на спину (поза "—")
    root.CFrame = root.CFrame * CFrame.Angles(math.rad(90), 0, 0)
    
    -- Создаём BodyPosition для удержания под картой
    if undergroundBodyPosition then
        undergroundBodyPosition:Destroy()
    end
    if undergroundBodyGyro then
        undergroundBodyGyro:Destroy()
    end
    
    undergroundBodyPosition = Instance.new("BodyPosition")
    undergroundBodyPosition.MaxForce = Vector3.new(100000, 100000, 100000)
    undergroundBodyPosition.P = 2000
    undergroundBodyPosition.D = 500
    undergroundBodyPosition.Position = root.Position + Vector3.new(0, -5, 0)
    undergroundBodyPosition.Parent = root
    
    undergroundBodyGyro = Instance.new("BodyGyro")
    undergroundBodyGyro.MaxTorque = Vector3.new(100000, 100000, 100000)
    undergroundBodyGyro.P = 2000
    undergroundBodyGyro.D = 500
    undergroundBodyGyro.CFrame = CFrame.new(root.Position) * CFrame.Angles(math.rad(90), 0, 0)
    undergroundBodyGyro.Parent = root
    
    humanoid.PlatformStand = true
    humanoid.Sit = true
    
    undergroundActive = true
    
    Window:Notify({
        Title = "Underground Farm",
        Content = "Teleported underground! Collecting " .. undergroundMode,
        Icon = "arrow-down",
        Duration = 3
    })
end

local function UndergroundCollectLoop()
    while undergroundFarm and undergroundActive do
        local char = LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        
        if not char or not root or not humanoid then
            undergroundActive = false
            break
        end
        
        -- Удерживаем позу лёжа
        root.CFrame = CFrame.new(root.Position) * CFrame.Angles(math.rad(90), 0, 0)
        humanoid.Sit = true
        humanoid.PlatformStand = true
        
        -- Ищем ближайшую цель
        local target, dist = GetClosestUndergroundTarget()
        
        if target then
            -- Двигаемся к цели (под картой)
            local targetPos = target.Position + Vector3.new(0, -2, 0)
            local diff = targetPos - root.Position
            local distance = diff.Magnitude
            
            if distance > 3 then
                -- Плавное перемещение
                local direction = diff.Unit
                local newPos = root.Position + direction * math.min(undergroundSpeed, distance)
                root.CFrame = CFrame.new(newPos) * CFrame.Angles(math.rad(90), 0, 0)
            end
            
            -- Обновляем BodyPosition
            if undergroundBodyPosition then
                undergroundBodyPosition.Position = root.Position + Vector3.new(0, -5, 0)
            end
            
            -- Проверяем, собрали ли мы цель
            if distance < 5 then
                -- Цель должна собраться автоматически через TouchInterest
                undergroundCollectCount = undergroundCollectCount + 1
            end
            
            task.wait(0.05)
        else
            -- Если целей нет, просто лежим под картой
            task.wait(0.5)
        end
        
        -- Проверка на отключение
        if not undergroundFarm then
            break
        end
    end
    
    -- Очистка
    if undergroundBodyPosition then
        undergroundBodyPosition:Destroy()
        undergroundBodyPosition = nil
    end
    if undergroundBodyGyro then
        undergroundBodyGyro:Destroy()
        undergroundBodyGyro = nil
    end
    
    local char = LocalPlayer.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if humanoid then
            humanoid.PlatformStand = false
            humanoid.Sit = false
        end
    end
    
    undergroundActive = false
    Window:Notify({
        Title = "Underground Farm",
        Content = "Underground farm stopped",
        Icon = "x-circle",
        Duration = 3
    })
end

local function StartUndergroundFarm()
    if undergroundFarm then
        -- Сначала останавливаем
        undergroundFarm = false
        undergroundActive = false
        if undergroundBodyPosition then
            undergroundBodyPosition:Destroy()
            undergroundBodyPosition = nil
        end
        if undergroundBodyGyro then
            undergroundBodyGyro:Destroy()
            undergroundBodyGyro = nil
        end
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.PlatformStand = false
                humanoid.Sit = false
            end
        end
        Window:Notify({
            Title = "Underground Farm",
            Content = "Disabled",
            Icon = "x-circle",
            Duration = 2
        })
        return
    end
    
    undergroundFarm = true
    
    -- Телепортируемся под карту
    local char = LocalPlayer.Character
    if not char then
        Window:Notify({
            Title = "Error",
            Content = "Character not found!",
            Icon = "x-circle",
            Duration = 3
        })
        undergroundFarm = false
        return
    end
    
    TeleportUnderground()
    
    -- Запускаем цикл сбора
    task.spawn(UndergroundCollectLoop)
end

