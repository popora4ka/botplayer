-- ================== ФУНКЦИИ ИГРОВОГО ПРОЦЕССА ==================
local function GetGameInfo()
    local gameInfo = {
        MapName = "Unknown",
        RoundActive = false,
        PlayerCount = #Players:GetPlayers(),
        Murderer = nil,
        Sheriff = nil,
        Innocents = {},
        Coins = {},
        Gun = nil,
        Alive = true,
        TimeLeft = 0
    }
    
    -- Поиск карты
    local mapFolder = Workspace:FindFirstChild("Map") or Workspace:FindFirstChild("Maps")
    if mapFolder then
        gameInfo.MapName = mapFolder.Name
    end
    
    -- Поиск монет
    local coinsFolder = Workspace:FindFirstChild("Coins") or Workspace:FindFirstChild("CoinContainer")
    if coinsFolder then
        for _, coin in ipairs(coinsFolder:GetChildren()) do
            if coin:IsA("BasePart") and coin.Transparency < 0.5 then
                table.insert(gameInfo.Coins, coin)
            end
        end
    end
    
    -- Определение ролей
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local character = player.Character
            if character then
                local playerInfo = {
                    Player = player,
                    Character = character,
                    Role = "Innocent",
                    HasGun = false,
                    Alive = true
                }
                
                -- Проверка на мардера (обычно имеет нож)
                for _, tool in ipairs(character:GetChildren()) do
                    if tool:IsA("Tool") then
                        local toolName = tool.Name:lower()
                        if toolName:find("knife") or toolName:find("blade") or toolName:find("sword") or toolName:find("murder") then
                            playerInfo.Role = "Murderer"
                            gameInfo.Murderer = player
                        elseif toolName:find("gun") or toolName:find("pistol") or toolName:find("revolver") or toolName:find("sheriff") then
                            playerInfo.Role = "Sheriff"
                            playerInfo.HasGun = true
                            gameInfo.Sheriff = player
                            gameInfo.Gun = tool
                        end
                        break
                    end
                end
                
                table.insert(gameInfo.Innocents, playerInfo)
            end
        end
    end
    
    -- Проверка жив ли игрок
    local localChar = LocalPlayer.Character
    gameInfo.Alive = localChar and localChar:FindFirstChild("Humanoid") and localChar.Humanoid.Health > 0
    
    -- Определение активного раунда
    local roundFolder = Workspace:FindFirstChild("RoundInfo") or Workspace:FindFirstChild("GameInfo")
    if roundFolder then
        local active = roundFolder:FindFirstChild("Active") or roundFolder:FindFirstChild("InRound")
        if active then
            gameInfo.RoundActive = active.Value
        end
        local timer = roundFolder:FindFirstChild("TimeLeft") or roundFolder:FindFirstChild("Timer")
        if timer then
            gameInfo.TimeLeft = timer.Value
        end
    end
    
    return gameInfo
end

local function GetNearestCoin()
    local localChar = LocalPlayer.Character
    if not localChar or not localChar:FindFirstChild("HumanoidRootPart") then return nil end
    
    local rootPart = localChar.HumanoidRootPart
    local nearestCoin = nil
    local nearestDistance = math.huge
    
    local gameInfo = GetGameInfo()
    for _, coin in ipairs(gameInfo.Coins) do
        if coin and coin.Parent then
            local distance = (coin.Position - rootPart.Position).Magnitude
            if distance < nearestDistance then
                nearestDistance = distance
                nearestCoin = coin
            end
        end
    end
    
    return nearestCoin
end

local function MoveToPosition(position)
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("Humanoid") then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    humanoid:MoveTo(position)
end

local function TweenToPosition(position, speed)
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    local rootPart = character.HumanoidRootPart
    local distance = (position - rootPart.Position).Magnitude
    local tweenInfo = TweenInfo.new(distance / speed, Enum.EasingStyle.Linear)
    
    local tween = TweenService:Create(rootPart, tweenInfo, {CFrame = CFrame.new(position)})
    tween:Play()
    
    return tween
end

local function CollectCoin(coin)
    if not coin or not coin.Parent then return false end
    
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    
    local rootPart = character.HumanoidRootPart
    
    -- Используем твин для подхода к монете
    local tween = TweenToPosition(coin.Position, Bot.WalkSpeed)
    tween.Completed:Wait()
    
    -- Симуляция сбора монеты через касание
    firetouchinterest(rootPart, coin, 0)
    wait(0.1)
    firetouchinterest(rootPart, coin, 1)
    
    collectedCoinsThisRound = collectedCoinsThisRound + 1
    return true
end

local function FindMurderer()
    local gameInfo = GetGameInfo()
    return gameInfo.Murderer
end

local function FindGun()
    local gun = Workspace:FindFirstChild("Gun") or Workspace:FindFirstChild("SheriffGun")
    if not gun then
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Tool") and (obj.Name:lower():find("gun") or obj.Name:lower():find("pistol") or obj.Name:lower():find("revolver")) then
                return obj
            end
        end
    end
    return gun
end

local function ShootAtPlayer(player)
    if not player or not player.Character then return end
    if time() - Bot.LastShootTime < 0.5 then return end -- Защита от спама
    
    Bot.LastShootTime = time()
    
    local character = LocalPlayer.Character
    if not character then return end
    
    -- Поиск оружия в инвентаре
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") and (tool.Name:lower():find("gun") or tool.Name:lower():find("pistol")) then
            -- Наводимся на цель
            local targetChar = player.Character
            if targetChar and targetChar:FindFirstChild("Head") then
                local targetPos = targetChar.Head.Position
                local mousePos = targetPos
                
                -- Симуляция клика для выстрела
                tool:Activate()
                wait(0.1)
                tool:Deactivate()
                
                return true
            end
        end
    end
    return false
end

local function VoteForMap(mapName)
