-- MainBot.lua - Основной файл с GUI и циклом бота

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")
local CoreGui = game:GetService("CoreGui")

wait(3)
local LocalPlayer = Players.LocalPlayer

-- Настройки бота
local Bot = {
    Enabled = false,
    CollectCoins = true,
    AutoVote = true,
    EscapeMurderer = true,
    AutoShoot = true,
    PickupGun = true,
    PlayerESP = true,
    GunESP = true,
    CoinESP = true,
    WalkSpeed = 60,
    LastShoot = 0,
    LastVote = 0,
    Connections = {},
    EspObjects = {}
}

-- Безопасный поиск
local function SafeFind(parent, name)
    if not parent then return nil end
    local s, r = pcall(function() return parent:FindFirstChild(name) end)
    return s and r or nil
end

-- Получение информации об игре
local function GetGameInfo()
    local info = {Coins = {}, Murderer = nil, Sheriff = nil, Gun = nil, Alive = true}
    
    -- Монеты
    local coins = SafeFind(Workspace, "Coins")
    if coins then
        for _, c in ipairs(coins:GetChildren()) do
            if c:IsA("BasePart") and c.Transparency < 0.5 then
                table.insert(info.Coins, c)
            end
        end
    end
    
    -- Роли игроков
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            for _, tool in ipairs(plr.Character:GetChildren()) do
                if tool:IsA("Tool") then
                    local n = tool.Name:lower()
                    if n:find("knife") then info.Murderer = plr
                    elseif n:find("gun") then info.Sheriff = plr; info.Gun = tool end
                end
            end
        end
    end
    
    -- Жив ли игрок
    local char = LocalPlayer.Character
    if char then
        local hum = SafeFind(char, "Humanoid")
        info.Alive = hum and hum.Health > 0
    end
    
    return info
end

-- Движение к монете
local function CollectCoin(coin)
    local char = LocalPlayer.Character
    if not char then return end
    local root = SafeFind(char, "HumanoidRootPart")
    if not root then return end
    
    local tween = TweenService:Create(root, TweenInfo.new((coin.Position - root.Position).Magnitude / Bot.WalkSpeed), {CFrame = CFrame.new(coin.Position)})
    tween:Play()
    tween.Completed:Wait()
    
    pcall(function()
        firetouchinterest(root, coin, 0)
        wait(0.1)
        firetouchinterest(root, coin, 1)
    end)
end

-- Побег от мардера
local function EscapeFromMurderer(murderer)
    local char = LocalPlayer.Character
    if not char then return end
    local localRoot = SafeFind(char, "HumanoidRootPart")
    local murdRoot = SafeFind(murderer.Character, "HumanoidRootPart")
    if not localRoot or not murdRoot then return end
    
    if (localRoot.Position - murdRoot.Position).Magnitude < 30 then
        local escape = localRoot.Position + (localRoot.Position - murdRoot.Position).Unit * 50
        TweenService:Create(localRoot, TweenInfo.new(0.5), {CFrame = CFrame.new(escape)}):Play()
    end
end

-- Выстрел
local function ShootAtPlayer(player)
    if time() - Bot.LastShoot < 0.5 then return end
    Bot.LastShoot = time()
    
    local char = LocalPlayer.Character
    if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") and tool.Name:lower():find("gun") then
            pcall(function() tool:Activate() wait(0.1) tool:Deactivate() end)
            return
        end
    end
end

-- Голосование
local function VoteForMap()
    if time() - Bot.LastVote < 5 then return end
    Bot.LastVote = time()
    
    local maps = {"Bank", "Hotel", "House", "Hospital", "School"}
    local map = maps[math.random(#maps)]
    
    pcall(function()
        local remotes = SafeFind(game:GetService("ReplicatedStorage"), "Remotes")
        if remotes then
            local vote = SafeFind(remotes, "VoteMap")
            if vote then vote:FireServer(map) end
        end
    end)
end

-- Обновление ESP
local function UpdateESP()
    for _, obj in ipairs(Bot.EspObjects) do
        pcall(function() obj:Destroy() end)
    end
    Bot.EspObjects = {}
    
    local info = GetGameInfo()
    
    -- ESP игроков
    if Bot.PlayerESP then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local color = plr == info.Murderer and Color3.new(1,0,0) or (plr == info.Sheriff and Color3.new(0,0,1) or Color3.new(0,1,0))
                local hl = Instance.new("Highlight")
                hl.FillColor = color
                hl.Parent = plr.Character
                table.insert(Bot.EspObjects, hl)
            end
        end
    end
    
    -- ESP оружия
    if Bot.GunESP and info.Gun then
        local hl = Instance.new("Highlight")
        hl.FillColor = Color3.new(1,1,0)
        hl.Parent = info.Gun
        table.insert(Bot.EspObjects, hl)
    end
    
    -- ESP монет
    if Bot.CoinESP then
        for _, coin in ipairs(info.Coins) do
            local hl = Instance.new("Highlight")
            hl.FillColor = Color3.new(1,1,0)
            hl.Parent = coin
            table.insert(Bot.EspObjects, hl)
        end
    end
end

-- Основной цикл
local function MainLoop()
    if not Bot.Enabled then return end
    
    local info = GetGameInfo()
    
    -- Сбор монет
    if Bot.CollectCoins and info.Alive then
        local nearest = nil
        local minDist = math.huge
        local char = LocalPlayer.Character
        if char then
            local root = SafeFind(char, "HumanoidRootPart")
            if root then
                for _, coin in ipairs(info.Coins) do
                    local dist = (coin.Position - root.Position).Magnitude
                    if dist < minDist then minDist = dist; nearest = coin end
                end
                if nearest then CollectCoin(nearest) end
            end
        end
    end
    
    -- Побег от мардера
    if Bot.EscapeMurderer and info.Murderer and info.Alive then
        EscapeFromMurderer(info.Murderer)
    end
    
    -- Авто-шут за шерифа
    if Bot.AutoShoot and info.Sheriff == LocalPlayer and info.Murderer then
        ShootAtPlayer(info.Murderer)
    end
    
    -- Голосование
    if Bot.AutoVote then VoteForMap() end
end

-- GUI
local function CreateGUI()
    local gui = Instance.new("ScreenGui")
    gui.Name = "MM2Bot"
    gui.Parent = CoreGui
    gui.ResetOnSpawn = false
    
    local frame = Instance.new("Frame")
    frame.Parent = gui
    frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    frame.Position = UDim2.new(0.7,0,0.3,0)
    frame.Size = UDim2.new(0,220,0,350)
    frame.Active = true
    frame.Draggable = true
    
    -- Заголовок
    local title = Instance.new("TextLabel")
    title.Parent = frame
    title.BackgroundColor3 = Color3.fromRGB(50,50,50)
    title.Size = UDim2.new(1,0,0,25)
    title.Text = "MM2 Bot"
    title.TextColor3 = Color3.new(1,1,1)
    title.Font = Enum.Font.GothamBold
    title.TextSize = 14
    
    -- Статус
    local status = Instance.new("TextLabel")
    status.Parent = frame
    status.Position = UDim2.new(0.05,0,0.1,0)
    status.Size = UDim2.new(0.9,0,0,30)
    status.BackgroundColor3 = Color3.fromRGB(40,40,40)
    status.Text = "Status: OFF"
    status.TextColor3 = Color3.new(1,0,0)
    status.Font = Enum.Font.Gotham
    status.TextSize = 12
    
    -- Создание переключателей
    local y = 0.2
    local function AddToggle(name, default, callback)
        local lbl = Instance.new("TextLabel")
        lbl.Parent = frame
        lbl.BackgroundColor3 = Color3.fromRGB(40,40,40)
        lbl.Position = UDim2.new(0.05,0,y,0)
        lbl.Size = UDim2.new(0.55,0,0,25)
        lbl.Text = name
        lbl.TextColor3 = Color3.new(1,1,1)
        lbl.Font = Enum.Font.Gotham
        lbl.TextSize = 11
        
        local btn = Instance.new("TextButton")
        btn.Parent = frame
        btn.BackgroundColor3 = default and Color3.new(0,1,0) or Color3.new(1,0,0)
        btn.Position = UDim2.new(0.65,0,y,0)
        btn.Size = UDim2.new(0.3,0,0,25)
        btn.Text = default and "ON" or "OFF"
        btn.TextColor3 = Color3.new(1,1,1)
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 11
        
        btn.MouseButton1Click:Connect(function()
            local state = btn.Text == "OFF"
            btn.Text = state and "ON" or "OFF"
            btn.BackgroundColor3 = state and Color3.new(0,1,0) or Color3.new(1,0,0)
            callback(state)
        end)
        
        y = y + 0.08
    end
    
    -- Кнопка вкл/выкл бота
    local mainBtn = Instance.new("TextButton")
    mainBtn.Parent = frame
    mainBtn.BackgroundColor3 = Color3.new(1,0,0)
    mainBtn.Position = UDim2.new(0.05,0,0.85,0)
    mainBtn.Size = UDim2.new(0.9,0,0,40)
    mainBtn.Text = "ENABLE BOT"
    mainBtn.TextColor3 = Color3.new(1,1,1)
    mainBtn.Font = Enum.Font.GothamBold
    mainBtn.TextSize = 16
    
    mainBtn.MouseButton1Click:Connect(function()
        Bot.Enabled = not Bot.Enabled
        if Bot.Enabled then
            mainBtn.Text = "DISABLE BOT"
            mainBtn.BackgroundColor3 = Color3.new(0,1,0)
            status.Text = "Status: ON"
            status.TextColor3 = Color3.new(0,1,0)
            Bot.Connections.Main = RunService.RenderStepped:Connect(MainLoop)
            Bot.Connections.ESP = RunService.RenderStepped:Connect(UpdateESP)
        else
            mainBtn.Text = "ENABLE BOT"
            mainBtn.BackgroundColor3 = Color3.new(1,0,0)
            status.Text = "Status: OFF"
            status.TextColor3 = Color3.new(1,0,0)
            for _, c in pairs(Bot.Connections) do pcall(function() c:Disconnect() end) end
            Bot.Connections = {}
        end
    end)
    
    AddToggle("Collect Coins", true, function(s) Bot.CollectCoins = s end)
    AddToggle("Auto Vote", true, function(s) Bot.AutoVote = s end)
    AddToggle("Escape Murderer", true, function(s) Bot.EscapeMurderer = s end)
    AddToggle("Auto Shoot", true, function(s) Bot.AutoShoot = s end)
    AddToggle("Player ESP", true, function(s) Bot.PlayerESP = s end)
    AddToggle("Gun ESP", true, function(s) Bot.GunESP = s end)
    AddToggle("Coin ESP", true, function(s) Bot.CoinESP = s end)
end

-- AdvancedFeatures.lua - Продвинутые функции бота

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local TweenService = game:GetService("TweenService")
local LocalPlayer = Players.LocalPlayer

local Advanced = {}

-- Авто-подбор оружия
function Advanced:AutoPickupGun()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    -- Ищем оружие на карте
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Tool") and obj.Name:lower():find("gun") then
            local dist = (obj.Position - root.Position).Magnitude
            if dist < 50 then
                local tween = TweenService:Create(root, TweenInfo.new(dist/60), {CFrame = CFrame.new(obj.Position)})
                tween:Play()
                tween.Completed:Wait()
                return true
            end
        end
    end
    return false
end

-- Прохождение препятствий
function Advanced:PassObstacles()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChild("Humanoid")
    if not root or not hum then return end
    
    -- Проверка препятствий впереди
    local rayOrigin = root.Position
    local rayDir = root.CFrame.LookVector * 5
    
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {char}
    params.FilterType = Enum.RaycastFilterType.Blacklist
    
    local result = Workspace:Raycast(rayOrigin, rayDir, params)
    
    if result and result.Instance:IsA("BasePart") and result.Instance.Size.Y > 2 then
        hum.Jump = true
        if result.Instance.Size.Y > 4 then
            wait(0.3)
            hum.Jump = true
        end
    end
end

-- Телепорт к монетам
function Advanced:TeleportToCoins()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local coins = Workspace:FindFirstChild("Coins")
    if not coins then return end
    
    for _, coin in ipairs(coins:GetChildren()) do
        if coin:IsA("BasePart") and coin.Transparency < 0.5 then
            root.CFrame = CFrame.new(coin.Position + Vector3.new(0,3,0))
            wait(0.1)
            pcall(function()
                firetouchinterest(root, coin, 0)
                firetouchinterest(root, coin, 1)
            end)
        end
    end
end

-- Анти-АФК
function Advanced:AntiAFK()
    local VirtualInputManager = game:GetService("VirtualInputManager")
    
    spawn(function()
        while true do
            wait(60)
            pcall(function()
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, nil)
                wait(0.1)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, nil)
            end)
        end
    end)
end

-- Авто-реконнект
function Advanced:AutoRejoin()
    local TeleportService = game:GetService("TeleportService")
    local placeId = game.PlaceId
    
    spawn(function()
        while true do
            wait(300) -- Проверка каждые 5 минут
            if #Players:GetPlayers() < 4 then -- Мало игроков
                pcall(function()
                    TeleportService:Teleport(placeId, LocalPlayer)
                end)
            end
        end
    end)
end

-- Авто-получение наград
function Advanced:ClaimRewards()
    local gui = LocalPlayer:FindFirstChild("PlayerGui")
    if not gui then return end
    
    -- Поиск кнопки наград
    for _, obj in ipairs(gui:GetDescendants()) do
        if obj:IsA("TextButton") then
            local text = obj.Text:lower()
            if text:find("claim") or text:find("reward") or text:find("daily") then
                pcall(function()
                    local remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                    if remotes then
                        local claim = remotes:FindFirstChild("ClaimReward")
                        if claim then claim:FireServer() end
                    end
                end)
            end
        end
    end
end

-- Фарм с телепортом
function Advanced:TeleportFarm()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local coins = Workspace:FindFirstChild("Coins")
    if not coins then return end
    
    local coinList = {}
    for _, coin in ipairs(coins:GetChildren()) do
        if coin:IsA("BasePart") then
            table.insert(coinList, coin)
        end
    end
    
    for _, coin in ipairs(coinList) do
        if not coin.Parent then continue end
        root.CFrame = CFrame.new(coin.Position + Vector3.new(0,2,0))
        wait(0.2)
        pcall(function()
            firetouchinterest(root, coin, 0)
            wait(0.1)
            firetouchinterest(root, coin, 1)
        end)
    end
end

-- Обход анти-чита
function Advanced:AntiCheatBypass()
    -- Отключаем обнаружение
    local det = Workspace:FindFirstChild("AntiCheat")
    if det then
        pcall(function()
            det:Destroy()
        end)
    end
    
    -- Скрываем GUI от обнаружения
    local gui = game:GetService("CoreGui"):FindFirstChild("MM2Bot")
    if gui then
        gui.Name = tostring(math.random(1000000))
        gui.ResetOnSpawn = false
    end
end

return Advanced
